{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "esnext"
    ],
    "outDir": "dist",
    "paths": {
      "src/*": [
        "./src"
      ]
    },
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true, // Flags unused local variables
    "noUnusedParameters": true, // Flags unused function parameters
    "noFallthroughCasesInSwitch": true, // Prevents fallthroughs in switch cases
    "noUncheckedIndexedAccess": true, // Flags potential undefined elements when accessing arrays or objects
    "moduleDetection": "force",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "strictNullChecks": true, // Ensures no nullable values unless explicitly typed as such
    "strictFunctionTypes": true, // Prevents incompatible function assignments
    "strictPropertyInitialization": true // Ensures properties are initialized in constructor,
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
