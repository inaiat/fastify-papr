{
  "name": "@inaiat/fastify-papr",
  "version": "10.0.0",
  "description": "Fastify Papr Plugin Integration",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.24.0",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "ts:loader": "FASTIFY_AUTOLOAD_TYPESCRIPT=true node --import=tsx/esm",
    "test": "pnpm ts:loader --test tests/*.ts",
    "build": "tsup",
    "fmt": "dprint fmt",
    "lint": "dprint check && oxlint",
    "lint:fix": "oxlint --fix",
    "coverage": "pnpm lint && c8 pnpm test",
    "prepublishOnly": "npm run build",
    "make-badges": "istanbul-badges-readme",
    "check-commit": "pnpm lint && pnpm test",
    "prepare": "husky || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inaiat/fastify-papr.git"
  },
  "keywords": [
    "fastify",
    "mongodb",
    "papr",
    "database",
    "model",
    "schema",
    "json",
    "json-schema",
    "validation",
    "typescript",
    "types",
    "fastify-plugin"
  ],
  "contributors": [
    "Inaiat <inaiat@gmail.com>",
    "Daniel Molina <dgmolina.ti@gmail.com>",
    "Murilo Alves <hi@omurilo.dev>"
  ],
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "http://opensource.org/licenses/MIT"
    }
  ],
  "homepage": "https://github.com/inaiat/fastify-papr.git",
  "dependencies": {
    "fastify-plugin": "^5.1.0",
    "papr": "^16.0.0"
  },
  "peerDependencies": {
    "fastify": "^5.6",
    "mongodb": "^7"
  },
  "devDependencies": {
    "@types/node": "^24.10",
    "@types/semver": "^7.7.1",
    "c8": "^10.1.3",
    "dprint": "^0.50",
    "husky": "^9.1.7",
    "istanbul-badges-readme": "^1.9.0",
    "mongodb": "^7.0.0",
    "mongodb-memory-server": "^10.3.0",
    "oxlint": "^1.31.0",
    "semver": "^7.7.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "directories": {
    "test": "test"
  },
  "tsup": {
    "sourcemap": true,
    "dts": true,
    "clean": true,
    "bundle": true,
    "target": "node24",
    "format": [
      "esm",
      "cjs"
    ],
    "entry": [
      "src/**/*.ts"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "json-summary",
      "lcov"
    ]
  },
  "config": {
    "mongodbMemoryServer": {
      "debug": "0"
    }
  },
  "author": "inaiat@gmail.com"
}
